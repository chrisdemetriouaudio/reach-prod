---
interface Props {
  title: string;
  eyebrow?: string;
  lead?: string;
}
const { title, eyebrow, lead } = Astro.props;
---
<section class="relative overflow-hidden border-b border-sand-200 bg-gradient-to-b from-sand-100 to-sand-50">
  <div class="pointer-events-none absolute inset-0 bg-cover bg-center opacity-80" style="background-image:url('/images/banner-inner.png')"></div>
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-sand-50/70 via-sand-50/30 to-transparent"></div>
  <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-accent-100/60 blur-3xl"></div>
  <div class="container-reach relative py-16 sm:py-20">
    <div class="max-w-3xl rounded-3xl bg-sand-50/80 p-6 shadow-sm ring-1 ring-sand-200/60 backdrop-blur-sm sm:p-8">
      {eyebrow && <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-accent-700">{eyebrow}</p>}
      <h1 class="text-gradient-warm text-4xl font-semibold sm:text-5xl">{title}</h1>
      <div class="rule-warm mt-5"></div>
      {lead && <p class="mt-5 text-lg leading-relaxed text-ink-700">{lead}</p>}
    </div>
  </div>
</section>
