---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const reps = [
  {
    name: 'Sr Theresa Abigaba',
    location: 'Fort Portal, Western Uganda',
    text: "Sr Theresa cares for vulnerable children at the Good Shepherd Special School, where many of the children R.E.A.CH supports live at St Gabriel's House. She identifies children in desperate need of a safe home and oversees their care and education.",
  },
  {
    name: 'Sr Evangelista Mirembe',
    location: 'Lira, Northern Uganda',
    text: 'Sr Evangelista works with vulnerable families through the Family Support Initiative and helped form the Lira Women’s Group, empowering women to better support their families in the long term.',
  },
  {
    name: 'Sebastian Waiswa',
    location: 'Jinja, Uganda',
    text: 'Sebastian helps set up and manage projects in Jinja, working alongside R.E.A.CH and our partner charity Helping Uganda Schools to support children and families in the area.',
  },
  {
    name: 'Ronald Kamoga',
    location: 'Kampala, Uganda',
    text: 'Ronald identifies children in the Kosovo slum for school-fee sponsorship and manages exciting education and self-sustaining projects in Kampala on our behalf.',
  },
];
---

<BaseLayout title="Our Trusted Representatives" description="R.E.A.CH operates through Trusted Representatives in Uganda who identify need and manage our projects on the ground.">
  <PageHeader
    eyebrow="About R.E.A.CH"
    title="Our Trusted Representatives"
    lead="We operate through Trusted Representatives in Uganda who identify the need and manage projects on our behalf. They are the reason we can keep overheads low and ensure funds reach the children who need them most."
  />

  <section class="container-reach py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {reps.map((r) => (
        <article class="rounded-3xl border border-sand-200 bg-white p-7">
          <h2 class="text-xl font-semibold">{r.name}</h2>
          <p class="mt-1 inline-flex items-center gap-1.5 text-sm font-medium text-accent-700">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
            {r.location}
          </p>
          <p class="mt-4 leading-relaxed text-ink-700">{r.text}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
