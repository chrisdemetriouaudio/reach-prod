---
import { nav, site } from '../data/site';
import BrandName from './BrandName.astro';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="sticky top-0 z-50 bg-sand-50/95 shadow-sm backdrop-blur">
  <div class="container-reach flex h-16 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-3" title={site.fullName}>
      <img src={site.logo} alt={site.fullName} width="44" height="44" class="h-11 w-auto" onerror="this.style.display='none'" />
      <BrandName class="max-w-[13rem] font-display text-sm font-bold leading-tight text-ink-900 sm:max-w-none sm:text-base" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:block" aria-label="Primary">
      <ul class="flex items-center gap-1">
        {nav.map((item) => (
          <li class="group relative">
            <a
              href={item.href}
              class:list={[
                'inline-flex items-center gap-1 rounded-full px-3.5 py-2 text-sm font-medium transition',
                isActive(item.href) ? 'text-accent-700' : 'text-ink-700 hover:text-accent-700',
              ]}
            >
              {item.label}
              {item.children && (
                <svg class="h-3 w-3 opacity-60" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              )}
            </a>
            {item.children && (
              <div class="invisible absolute left-0 top-full z-50 w-72 pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                <ul class="rounded-2xl border border-sand-200 bg-white p-2 shadow-lg shadow-ink-900/5">
                  {item.children.map((child) => (
                    <li>
                      <a href={child.href} class="block rounded-xl px-3 py-2 text-sm text-ink-700 hover:bg-sand-50 hover:text-accent-700">
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a href="/donate" class="btn-primary !px-5 !py-2">Donate</a>
    </div>

    <!-- Mobile toggle -->
    <button id="nav-toggle" class="lg:hidden grid h-10 w-10 place-items-center rounded-lg text-ink-800 hover:bg-sand-100" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-nav" class="hidden max-h-[calc(100dvh-4.5rem)] overflow-y-auto overscroll-contain border-t border-sand-200 bg-sand-50 lg:hidden">
    <nav class="container-reach py-4" aria-label="Mobile">
      <ul class="space-y-1">
        {nav.map((item) => (
          <li>
            {item.children ? (
              <details class="group">
                <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2 font-medium text-ink-800 hover:bg-sand-100 [&::-webkit-details-marker]:hidden">
                  {item.label}
                  <svg class="h-4 w-4 text-ink-500 transition group-open:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </summary>
                <ul class="ml-3 border-l border-sand-200 pl-3">
                  <li><a href={item.href} class="block rounded-lg px-3 py-1.5 text-sm font-medium text-accent-700 hover:bg-sand-100">{item.label} overview</a></li>
                  {item.children.map((child) => (
                    <li><a href={child.href} class="block rounded-lg px-3 py-1.5 text-sm text-ink-600 hover:bg-sand-100">{child.label}</a></li>
                  ))}
                </ul>
              </details>
            ) : (
              <a href={item.href} class="block rounded-lg px-3 py-2 font-medium text-ink-800 hover:bg-sand-100">{item.label}</a>
            )}
          </li>
        ))}
      </ul>
      <a href="/donate" class="btn-primary mt-4 w-full">Donate</a>
    </nav>
  </div>
  <div class="h-1.5 w-full bg-gradient-to-r from-gold-400 via-accent-500 to-accent-700"></div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
