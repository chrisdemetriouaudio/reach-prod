---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

const featured = projects.filter((p) => p.featured).slice(0, 3);

const stats = [
  { value: '1992', label: 'Founded in Bury, Lancashire' },
  { value: '£8–10k', label: 'Raised for children each year' },
  { value: '100%', label: 'Run by unpaid volunteer trustees' },
];

const sponsorship = [
  { amount: '£20', period: 'per month', text: 'Provides a secondary school child with food, accommodation and education.' },
  { amount: '£12.50', period: 'per month', text: 'Helps support a primary school child with their educational needs and care.' },
  { amount: '£2', period: 'per month', text: 'Provides a uniform and clothing.' },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 bg-cover bg-center opacity-80" style="background-image:url('/images/banner-home.png')"></div>
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-sand-50/40 via-transparent to-sand-50"></div>
    <div class="pointer-events-none absolute -left-32 top-10 h-80 w-80 rounded-full bg-accent-100/70 blur-3xl"></div>
    <div class="pointer-events-none absolute right-0 top-40 h-72 w-72 rounded-full bg-sand-200/70 blur-3xl"></div>
    <div class="container-reach relative grid items-center gap-12 py-20 lg:grid-cols-12 lg:py-28">
      <div class="rounded-3xl bg-sand-50/80 p-6 shadow-sm ring-1 ring-sand-200/60 backdrop-blur-sm sm:p-8 lg:col-span-7">
        <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-accent-200 bg-gold-500/15 px-4 py-1.5 text-sm font-semibold text-accent-700">
          <span class="h-2 w-2 rounded-full bg-gold-500"></span> Reaching East Africa's CHildren
        </p>
        <h1 class="text-gradient-warm text-4xl font-semibold leading-tight sm:text-5xl lg:text-6xl">
          Education is no weight to carry.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-700">
          R.E.A.CH helps to educate and care for vulnerable children in Uganda. We believe all
          children should have a childhood — and that a good education is the surest way out of poverty.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/donate" class="btn-primary">Sponsor a child</a>
          <a href="/about" class="btn-ghost">Find out more</a>
        </div>
      </div>
      <div class="lg:col-span-5">
        <div class="rounded-3xl border border-sand-200 bg-white p-2 shadow-xl shadow-ink-900/5">
          <img
            src="/images/BAO-child.gif"
            alt="A child supported by R.E.A.CH in Uganda"
            width="600" height="690" loading="eager" decoding="async"
            class="aspect-[5/6] w-full rounded-2xl object-cover"
            onerror="this.onerror=null;this.src='/images/placeholder.svg';this.classList.add('img-fallback');"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-y border-sand-200 bg-white">
    <div class="container-reach grid gap-8 py-10 sm:grid-cols-3">
      {stats.map((s) => (
        <div class="text-center sm:text-left">
          <p class="text-gradient-warm font-display text-4xl font-bold">{s.value}</p>
          <p class="mt-1 text-sm text-ink-600">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Intro -->
  <section class="container-reach py-20">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 class="text-3xl font-semibold sm:text-4xl">Who we are</h2>
        <div class="prose-reach mt-6">
          <p>
            R.E.A.CH (Reaching East Africa's Children) helps to educate and care for vulnerable
            children in Uganda. Our philosophy is that 'all children should have a childhood' and
            that 'education is no weight to carry.'
          </p>
          <p>
            We are proud of our minimal overheads and publish details of all the charity costs so
            our donors can be reassured that their money is being managed and spent in the most
            effective way.
          </p>
          <p>
            We operate through 'Trusted Representatives' in Uganda who identify the need and manage
            the projects on our behalf. Whilst our primary focus is education, we also fund a number
            of small projects which we hope will become sustainable in the future.
          </p>
        </div>
        <a href="/about" class="mt-6 inline-flex items-center gap-2 font-semibold text-accent-700 hover:text-accent-800">
          How R.E.A.CH works
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <!-- Sponsorship -->
      <div class="rounded-3xl border border-sand-200 bg-sand-100/60 p-8">
        <h3 class="text-xl font-semibold">What your support provides</h3>
        <p class="mt-2 text-sm text-ink-600">Every contribution goes directly to the children and projects we support.</p>
        <ul class="mt-6 space-y-4">
          {sponsorship.map((s) => (
            <li class="flex items-start gap-4 rounded-2xl bg-white p-4 shadow-sm">
              <div class="shrink-0 text-right">
                <span class="text-gradient-warm block font-display text-2xl font-bold">{s.amount}</span>
                <span class="text-xs text-ink-500">{s.period}</span>
              </div>
              <p class="text-sm leading-relaxed text-ink-700">{s.text}</p>
            </li>
          ))}
        </ul>
        <a href="/donate" class="btn-primary mt-6 w-full">Ways to donate</a>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="border-t border-sand-200 bg-white">
    <div class="container-reach py-20">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-accent-700">Our work</p>
          <h2 class="mt-2 text-3xl font-semibold sm:text-4xl">Projects we support</h2>
        </div>
        <a href="/projects" class="btn-ghost">View all projects</a>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featured.map((p) => (
          <a href={`/projects/${p.slug}`} class="group flex flex-col rounded-3xl border border-sand-200 bg-sand-50 p-6 hover-lift hover:border-accent-300">
            <h3 class="text-lg font-semibold group-hover:text-accent-700">{p.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-600">{p.summary}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-700">
              Read more
              <svg class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-reach py-20">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-accent-500 via-accent-600 to-accent-700 px-8 py-14 text-center text-white sm:px-16">
      <div class="pointer-events-none absolute -right-10 -top-10 h-48 w-48 rounded-full bg-gold-400/30 blur-2xl"></div>
      <div class="pointer-events-none absolute -bottom-12 -left-8 h-48 w-48 rounded-full bg-accent-800/40 blur-2xl"></div>
      <div class="relative z-10">
        <h2 class="text-3xl font-semibold text-white sm:text-4xl">Help a child stay in school</h2>
        <p class="mx-auto mt-4 max-w-2xl text-accent-50">
          With minimal overheads and trusted representatives on the ground, your donation reaches the
          children who need it most. Set up a regular gift or make a one-off donation today.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/donate" class="btn bg-white text-accent-700 hover:bg-sand-100">Donate now</a>
          <a href="/contact-us" class="btn border border-white/40 text-white hover:bg-white/10">Get in touch</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
