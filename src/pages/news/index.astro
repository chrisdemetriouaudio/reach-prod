---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { news } from '../../data/news';
---

<BaseLayout title="News & Events" description="Fundraising events and news from R.E.A.CH — from clothes swaps and tea parties to family film nights, all raising funds for vulnerable children in Uganda.">
  <PageHeader
    eyebrow="What's on"
    title="News & Events"
    lead="From clothes swaps to film nights, our supporters across the UK hold all kinds of events to raise funds for the children we support."
  />

  <section class="container-reach py-16">
    <div class="grid gap-6 sm:grid-cols-2">
      {news.map((post) => (
        <a href={`/news/${post.slug}`} class="group flex flex-col rounded-3xl border border-sand-200 bg-white p-6 hover-lift hover:border-accent-300">
          <p class="inline-flex w-fit items-center gap-2 rounded-full bg-accent-50 px-3 py-1 text-xs font-semibold text-accent-700">{post.eventDate}</p>
          <h2 class="mt-4 text-lg font-semibold group-hover:text-accent-700">{post.title}</h2>
          <p class="mt-1 text-sm text-ink-500">{post.venue}, {post.location}</p>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-600">{post.blurb}</p>
          <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-700">
            Read more
            <svg class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
