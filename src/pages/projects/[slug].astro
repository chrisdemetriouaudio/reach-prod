---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Img from '../../components/Img.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const others = projects.filter((p) => p.slug !== project.slug).slice(0, 3);
---

<BaseLayout title={project.title} description={project.summary}>
  <PageHeader eyebrow="Project" title={project.title} lead={project.summary} />

  <article class="container-reach py-16">
    {project.gallery && project.gallery.length > 0 && (
      <div class="mb-10 grid gap-4 sm:grid-cols-2">
        {project.gallery.map((g) => (
          <Img src={g.src} alt={g.alt} width={800} height={600} class="aspect-[4/3] w-full rounded-2xl border border-sand-200 object-cover" />
        ))}
      </div>
    )}

    <div class="prose-reach max-w-3xl">
      {project.sections.map((section) => (
        <div>
          {section.heading && <h2>{section.heading}</h2>}
          {section.paragraphs?.map((p) => <p>{p}</p>)}
          {section.list && <ul>{section.list.map((li) => <li>{li}</li>)}</ul>}
        </div>
      ))}

      {project.stub && (
        <p class="mt-8 rounded-xl border border-sand-200 bg-sand-100/60 p-4 text-sm text-ink-600">
          Some of the original detail for this page could not be recovered from the website archive.
          If you can help us complete it, please <a href="/contact-us">get in touch</a>.
        </p>
      )}
    </div>

    <div class="mt-12 flex flex-wrap gap-3">
      <a href="/donate" class="btn-primary">Support this work</a>
      <a href="/projects" class="btn-ghost">All projects</a>
    </div>
  </article>

  <section class="border-t border-sand-200 bg-white">
    <div class="container-reach py-14">
      <h2 class="text-xl font-semibold">More projects</h2>
      <div class="mt-6 grid gap-6 sm:grid-cols-3">
        {others.map((p) => (
          <a href={`/projects/${p.slug}`} class="group rounded-2xl border border-sand-200 bg-sand-50 p-5 hover-lift hover:border-accent-300">
            <h3 class="font-semibold group-hover:text-accent-700">{p.title}</h3>
            <p class="mt-2 line-clamp-3 text-sm text-ink-600">{p.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
