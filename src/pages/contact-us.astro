---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { site } from '../data/site';

const turnstileKey = site.turnstileSiteKey;
const endpoint = site.contactEndpoint;
---

<BaseLayout title="Contact Us" description="Get in touch with R.E.A.CH to talk about our work, fundraising or a trip to Uganda.">
  <PageHeader
    eyebrow="Get in touch"
    title="Contact Us"
    lead="If you would like to talk to us about the work of R.E.A.CH, are thinking of doing a fundraising event, or even considering a trip to Uganda, then please get in touch."
  />

  <section class="container-reach py-16">
    <div class="grid gap-12 lg:grid-cols-2">
      <!-- Details -->
      <div>
        <h2 class="text-2xl font-semibold">Reach us directly</h2>
        <dl class="mt-6 space-y-6">
          <div class="flex items-start gap-4">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-accent-50 text-accent-700">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
            </span>
            <div>
              <dt class="text-sm font-semibold uppercase tracking-wider text-ink-500">Email</dt>
              <dd class="mt-1"><a href={`mailto:${site.email}`} class="text-accent-700 hover:text-accent-800">{site.email}</a></dd>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-accent-50 text-accent-700">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2a9.88 9.88 0 0 0-8.45 14.96L2 22l5.2-1.36A9.88 9.88 0 1 0 12.04 2Zm0 1.8a8.08 8.08 0 0 1 6.86 12.37l-.35.55.78 2.84-2.92-.76-.53.31A8.08 8.08 0 1 1 12.04 3.8Zm5.8 12.24c-.25.69-1.45 1.32-1.99 1.36-.53.05-1.03.24-3.48-.72-2.94-1.16-4.8-4.16-4.94-4.35-.14-.18-1.18-1.56-1.18-2.98 0-1.42.74-2.12 1-2.4.26-.3.56-.37.75-.37h.54c.17 0 .4-.06.63.49.24.57.81 1.98.88 2.12.07.14.12.3.02.5-.1.19-.14.31-.28.48-.14.16-.3.37-.43.5-.14.14-.29.29-.13.57.16.28.74 1.22 1.6 1.98 1.1.98 2.03 1.29 2.32 1.43.29.14.46.12.64-.08.18-.19.73-.85.92-1.14.2-.28.39-.24.65-.14.26.1 1.68.8 1.96.94.29.14.48.21.55.33.07.12.07.7-.17 1.38Z"/></svg>
            </span>
            <div>
              <dt class="text-sm font-semibold uppercase tracking-wider text-ink-500">WhatsApp</dt>
              <dd class="mt-1"><a href={site.whatsapp} target="_blank" rel="noopener" class="text-accent-700 hover:text-accent-800">{site.phone}</a></dd>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-accent-50 text-accent-700">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
            </span>
            <div>
              <dt class="text-sm font-semibold uppercase tracking-wider text-ink-500">Registered Office</dt>
              <dd class="mt-1 not-italic text-ink-800">
                {site.address.name}<br />
                {site.address.lines.map((l) => <>{l}<br /></>)}
              </dd>
            </div>
          </div>
        </dl>
      </div>

      <!-- Form: posts to a Cloudflare Worker that verifies Turnstile + honeypot, then forwards to Formspree. -->
      <div class="rounded-3xl border border-sand-200 bg-white p-7">
        <h2 class="text-2xl font-semibold">Send us a message</h2>
        <p class="mt-2 text-sm text-ink-500">We'll get back to you by email as soon as we can.</p>

        <form id="contact-form" class="mt-6 space-y-4" novalidate>
          <div>
            <label for="name" class="block text-sm font-medium text-ink-700">Your name</label>
            <input id="name" name="name" type="text" required autocomplete="name" class="mt-1 w-full rounded-xl border border-sand-300 bg-sand-50 px-4 py-2.5 focus:border-accent-400 focus:outline-none focus:ring-2 focus:ring-accent-100" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-ink-700">Your email</label>
            <input id="email" name="email" type="email" required autocomplete="email" class="mt-1 w-full rounded-xl border border-sand-300 bg-sand-50 px-4 py-2.5 focus:border-accent-400 focus:outline-none focus:ring-2 focus:ring-accent-100" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-ink-700">Message</label>
            <textarea id="message" name="message" rows="5" required class="mt-1 w-full rounded-xl border border-sand-300 bg-sand-50 px-4 py-2.5 focus:border-accent-400 focus:outline-none focus:ring-2 focus:ring-accent-100"></textarea>
          </div>

          <!-- Honeypot: hidden from people, tempting to bots. If filled, we drop it. -->
          <div class="absolute left-[-9999px]" aria-hidden="true">
            <label>Leave this field empty<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
          </div>
          <!-- Email subject line in the charity inbox -->
          <input type="hidden" name="_subject" value="New enquiry from the R.E.A.CH website" />

          {turnstileKey && (
            <div class="cf-turnstile" data-sitekey={turnstileKey} data-theme="light" data-size="flexible"></div>
          )}

          <button type="submit" id="contact-submit" class="btn-primary w-full">Send message</button>

          <p id="contact-status" class="hidden rounded-xl px-4 py-3 text-sm" role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </section>

  {turnstileKey && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )}

  <script is:inline define:vars={{ endpoint, turnstileKey, email: site.email }}>
    const form = document.getElementById('contact-form');
    const statusEl = document.getElementById('contact-status');
    const submitBtn = document.getElementById('contact-submit');

    function show(message, kind) {
      statusEl.textContent = message;
      statusEl.className =
        'rounded-xl px-4 py-3 text-sm ' +
        (kind === 'ok'
          ? 'bg-green-50 text-green-800'
          : kind === 'warn'
          ? 'bg-amber-50 text-amber-800'
          : 'bg-accent-50 text-accent-800');
      statusEl.classList.remove('hidden');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!endpoint) {
        show('The contact form is not connected yet. In the meantime, please email us at ' + email + '.', 'warn');
        return;
      }

      // Cloudflare Turnstile injects this hidden field into the form once solved.
      const tokenField = form.querySelector('[name="cf-turnstile-response"]');
      const token = tokenField ? tokenField.value : '';
      if (turnstileKey && !token) {
        show('Please complete the anti-spam check before sending.', 'warn');
        return;
      }

      const data = new FormData(form);
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            name: data.get('name'),
            email: data.get('email'),
            message: data.get('message'),
            _gotcha: data.get('_gotcha') || '',
            token,
          }),
        });
        const out = await res.json().catch(() => ({}));
        if (res.ok && out.ok) {
          form.reset();
          if (typeof turnstile !== 'undefined') turnstile.reset();
          show('Thank you! Your message has been sent. We’ll be in touch soon.', 'ok');
        } else {
          show((out && out.error) || 'Sorry, something went wrong. Please email us directly at ' + email + '.', 'err');
          if (typeof turnstile !== 'undefined') turnstile.reset();
        }
      } catch (err) {
        show('Sorry, your message could not be sent. Please email us directly at ' + email + '.', 'err');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send message';
      }
    });
  </script>
</BaseLayout>
