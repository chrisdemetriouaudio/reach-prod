---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { site } from '../data/site';

const tiers = [
  { amount: '£20', period: 'per month', text: 'Provides a secondary school child with food, accommodation and education.' },
  { amount: '£12.50', period: 'per month', text: 'Helps support a primary school child with their educational needs and care.' },
  { amount: '£2', period: 'per month', text: 'Provides a uniform and clothing.' },
];

const ways = [
  'Using PayPal (button below).',
  'Cheque made payable to "Bury African Outreach" and posted to our registered address. (R.E.A.CH is our working name, but Bury African Outreach remains the name on our bank account.)',
  'Visa / Mastercard / Maestro debit etc. — please contact us to set this up.',
];
---

<BaseLayout title="Donate" description="Set up a regular gift or make a one-off donation to help educate and care for vulnerable children in Uganda. From £2 a month, your support makes a real difference.">
  <PageHeader
    eyebrow="Support our work"
    title="Donate"
    lead="If you would like to set up a direct debit or arrange a fundraising event, here is everything you need to know."
  />

  <!-- Sponsorship tiers -->
  <section class="container-reach py-16">
    <h2 class="text-2xl font-semibold sm:text-3xl">What's the cost of supporting one Ugandan child?</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-3">
      {tiers.map((t) => (
        <div class="rounded-3xl border border-sand-200 bg-white p-7 text-center">
          <p class="text-gradient-warm font-display text-4xl font-bold">{t.amount}</p>
          <p class="text-sm text-ink-500">{t.period}</p>
          <p class="mt-4 text-sm leading-relaxed text-ink-600">{t.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- PayPal -->
  <section class="border-y border-sand-200 bg-white">
    <div class="container-reach grid items-center gap-10 py-16 md:grid-cols-2">
      <div>
        <h2 class="text-2xl font-semibold sm:text-3xl">Secure donations via PayPal</h2>
        <p class="mt-4 leading-relaxed text-ink-700">
          The quickest way to give is through PayPal — you can make a one-off gift or set up a regular
          donation using a card or your PayPal balance. Every penny goes towards the education and care
          of the children we support.
        </p>
        <form action="https://www.paypal.com/donate" method="post" target="_top" class="mt-6">
          <input type="hidden" name="hosted_button_id" value="Z4TJXHTMXUBE2" />
          <button type="submit" class="btn-primary">Donate with PayPal</button>
        </form>
      </div>
      <div class="rounded-3xl bg-sand-100/70 p-8">
        <h3 class="text-lg font-semibold">There are many ways to donate</h3>
        <ul class="mt-4 space-y-3">
          {ways.map((w) => (
            <li class="flex items-start gap-3 text-sm leading-relaxed text-ink-700">
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-accent-500"></span>
              {w}
            </li>
          ))}
        </ul>
        <a href="/contact-us" class="mt-6 inline-flex items-center gap-2 font-semibold text-accent-700 hover:text-accent-800">
          Contact us to set up a donation
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Gift Aid -->
  <section class="container-reach py-16">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-semibold sm:text-3xl">Gift Aid</h2>
      <div class="prose-reach mt-4">
        <p>
          Gift Aid is a great scheme! By confirming that you are a UK taxpayer, the government will
          increase your donation by a further 25%. In other words, if you donated £100 then the charity
          would receive a further £25 in Gift Aid. All you need to do is sign a Gift Aid form and send
          it back to us.
        </p>
        <p>
          Donations made under UK Gift Aid have enabled us to substantially increase our support to the
          children at no extra cost to our sponsors. Please
          <a href={`mailto:${site.email}`}>email us</a> for a copy of our Gift Aid form.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
