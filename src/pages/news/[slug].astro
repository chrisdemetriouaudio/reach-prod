---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { news } from '../../data/news';

export function getStaticPaths() {
  return news.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
---

<BaseLayout title={post.title} description={post.blurb}>
  <PageHeader eyebrow="News & Events" title={post.title} />

  <article class="container-reach py-16">
    <div class="mx-auto max-w-3xl">
      <dl class="grid grid-cols-2 gap-4 rounded-2xl border border-sand-200 bg-white p-6 sm:grid-cols-3">
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-ink-500">Date</dt>
          <dd class="mt-1 font-medium text-ink-800">{post.eventDate}</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-ink-500">Venue</dt>
          <dd class="mt-1 font-medium text-ink-800">{post.venue}</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wider text-ink-500">Location</dt>
          <dd class="mt-1 font-medium text-ink-800">{post.location}</dd>
        </div>
      </dl>

      <div class="prose-reach mt-8">
        <p>{post.blurb}</p>
        <p>
          Events like this are organised by R.E.A.CH supporters across the UK and every penny raised
          goes towards the education and care of vulnerable children in Uganda. If you would like to
          host your own fundraising event, we would love to hear from you.
        </p>
      </div>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/donate" class="btn-primary">Donate</a>
        <a href="/contact-us" class="btn-ghost">Host an event</a>
        <a href="/news" class="btn-ghost">All news</a>
      </div>
    </div>
  </article>
</BaseLayout>
