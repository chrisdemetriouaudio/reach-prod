---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found">
  <section class="container-reach py-28 text-center">
    <p class="font-display text-6xl font-bold text-accent-700">404</p>
    <h1 class="mt-4 text-3xl font-semibold">We couldn't find that page</h1>
    <p class="mx-auto mt-3 max-w-md text-ink-600">The page you're looking for may have moved. Try heading back to the homepage or exploring our projects.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn-primary">Back to home</a>
      <a href="/projects" class="btn-ghost">Our projects</a>
    </div>
  </section>
</BaseLayout>
