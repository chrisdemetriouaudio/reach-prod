---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { projects } from '../../data/projects';
---

<BaseLayout title="Projects" description="R.E.A.CH runs a variety of projects supporting some of the most vulnerable people in Uganda's society. Whilst our primary focus is education, we also fund small projects that we hope will become sustainable.">
  <PageHeader
    eyebrow="Our work"
    title="Projects we support"
    lead="R.E.A.CH runs a variety of projects supporting some of the most vulnerable people in Uganda. Whilst our primary focus is education, we also fund a number of small projects which we hope will become sustainable in the future."
  />

  <section class="container-reach py-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <a href={`/projects/${p.slug}`} class="group flex flex-col rounded-3xl border border-sand-200 bg-white p-6 hover-lift hover:border-accent-300">
          <div class="flex items-center gap-2">
            <h2 class="text-lg font-semibold group-hover:text-accent-700">{p.title}</h2>
          </div>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-600">{p.summary}</p>
          <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-700">
            Read more
            <svg class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
