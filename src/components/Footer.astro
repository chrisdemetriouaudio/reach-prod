---
import { site, nav } from '../data/site';
import BrandName from './BrandName.astro';
const year = new Date().getFullYear();
---

<footer class="mt-24 bg-ink-900 text-sand-100">
  <div class="h-1.5 w-full bg-gradient-to-r from-gold-400 via-accent-500 to-accent-700"></div>
  <div class="container-reach grid items-start gap-y-8 py-14 lg:grid-cols-3 lg:gap-x-0">
    <div class="lg:pr-10">
      <div class="flex items-center gap-3">
        <img src={site.logo} alt={site.fullName} width="44" height="44" class="h-11 w-auto" onerror="this.style.display='none'" />
        <BrandName class="font-display text-base font-bold leading-tight text-white" highlightClass="text-gold-400" />
      </div>
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-sand-200">{site.description}</p>
    </div>

    <div class="border-t border-white/10 pt-8 lg:border-l lg:border-t-0 lg:px-10 lg:pt-0">
      <h2 class="flex h-11 items-center font-display text-sm font-semibold uppercase tracking-wider text-gold-400">Explore</h2>
      <ul class="mt-4 grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
        {nav.map((item) => (
          <li><a href={item.href} class="text-sand-200 transition-colors hover:text-gold-400">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="border-t border-white/10 pt-8 lg:border-l lg:border-t-0 lg:pl-10 lg:pt-0">
      <h2 class="flex h-11 items-center font-display text-sm font-semibold uppercase tracking-wider text-gold-400">Get in touch</h2>
      <address class="mt-4 space-y-2.5 text-sm not-italic text-sand-200">
        <p class="flex items-start gap-2.5">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3a2.85 2.85 0 0 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3Z"/><path d="m15 5 4 4"/></svg>
          <span class="leading-relaxed">{site.address.name}<br />{site.address.lines.join(', ')}</span>
        </p>
        <a href={`mailto:${site.email}`} class="flex items-center gap-2.5 text-sand-200 transition-colors hover:text-gold-400">
          <svg class="h-4 w-4 shrink-0 text-accent-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>
          <span class="break-all">{site.email}</span>
        </a>
        <a href={site.whatsapp} target="_blank" rel="noopener" class="flex items-center gap-2.5 text-sand-200 transition-colors hover:text-gold-400">
          <svg class="h-4 w-4 shrink-0 text-accent-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2a9.88 9.88 0 0 0-8.45 14.96L2 22l5.2-1.36A9.88 9.88 0 1 0 12.04 2Zm0 1.8a8.08 8.08 0 0 1 6.86 12.37l-.35.55.78 2.84-2.92-.76-.53.31A8.08 8.08 0 1 1 12.04 3.8Zm5.8 12.24c-.25.69-1.45 1.32-1.99 1.36-.53.05-1.03.24-3.48-.72-2.94-1.16-4.8-4.16-4.94-4.35-.14-.18-1.18-1.56-1.18-2.98 0-1.42.74-2.12 1-2.4.26-.3.56-.37.75-.37h.54c.17 0 .4-.06.63.49.24.57.81 1.98.88 2.12.07.14.12.3.02.5-.1.19-.14.31-.28.48-.14.16-.3.37-.43.5-.14.14-.29.29-.13.57.16.28.74 1.22 1.6 1.98 1.1.98 2.03 1.29 2.32 1.43.29.14.46.12.64-.08.18-.19.73-.85.92-1.14.2-.28.39-.24.65-.14.26.1 1.68.8 1.96.94.29.14.48.21.55.33.07.12.07.7-.17 1.38Z"/></svg>
          <span>{site.phone}</span>
        </a>
      </address>
      <a href={site.facebook} class="mt-4 inline-flex items-center gap-2 text-sm text-sand-200 transition-colors hover:text-gold-400" rel="noopener" target="_blank">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h3l.5-3H14V4.5c0-.9.3-1.5 1.6-1.5H18V.2C17.6.1 16.5 0 15.3 0 12.6 0 11 1.7 11 4.2V6H8v3h3v9h3V9z"/></svg>
        Facebook
      </a>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-reach flex flex-col items-center gap-1 py-6 text-center text-xs text-sand-300">
      <p>&copy; {year} {site.fullName}. All rights reserved.</p>
      <p>Registered charity ({site.charityNumber}) working to support vulnerable children in Uganda.</p>
      <p><a href="/privacy" class="text-sand-300 underline underline-offset-2 transition-colors hover:text-gold-400">Privacy &amp; Cookies</a></p>
    </div>
  </div>
</footer>
